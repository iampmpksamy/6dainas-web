# =============================================================================
#  6dainas-web — Caddy Site Blocks
#  All public-facing domains owned by this project live here.
# =============================================================================
#
#  Domains managed:
#    6dainas.cloud          — Next.js brand & marketing website (Docker :3000)
#    www.6dainas.cloud      — Redirects to apex
#    telemetry.6dainas.cloud — Go telemetry service (systemd :7000)
#
#  The 6DAiNAS-OS product has its own separate Caddyfile.
#  These configs are independent — do NOT mix them.
#
#  Prerequisites:
#    1. Next.js container running:
#         WEB_IMAGE=ghcr.io/iampmpksamy/6dainas-web:main \
#           docker compose -f infra/docker/docker-compose.prod.yml up -d
#       Binds to 127.0.0.1:3000
#
#    2. Telemetry service running:
#         sudo bash services/telemetry/Installer/install.sh
#       Runs on port 7000 via systemd
#
#    3. DNS (all → your HomeLab IP, Cloudflare orange cloud, Full strict SSL):
#         A  6dainas.cloud
#         A  www.6dainas.cloud
#         A  telemetry.6dainas.cloud
# =============================================================================

# ── www → apex redirect ───────────────────────────────────────────────────────
www.6dainas.cloud {
    redir https://6dainas.cloud{uri} permanent
}

# ── Brand & marketing website ─────────────────────────────────────────────────
6dainas.cloud {

    reverse_proxy localhost:3000 {
        transport http {
            dial_timeout            5s
            response_header_timeout 30s
            keepalive               30s
        }
        header_up X-Real-IP         {remote_host}
        header_up X-Forwarded-For   {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    header {
        X-Frame-Options         "SAMEORIGIN"
        X-Content-Type-Options  "nosniff"
        Referrer-Policy         "strict-origin-when-cross-origin"
        Permissions-Policy      "geolocation=(), microphone=(), camera=()"
        # Next.js inline scripts + Google Fonts + telemetry beacon
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://telemetry.6dainas.cloud; frame-ancestors 'none'"
        -Server
        -X-Powered-By
    }

    @tls_active `{tls_version} != ""`
    header @tls_active Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    encode {
        zstd
        gzip 6
        minimum_length 1024
    }

    log {
        output file /var/log/6dainas/web-access.log {
            roll_size    50MiB
            roll_keep    14
            roll_keep_for 336h
        }
        format json
    }
}

# ── Telemetry service ─────────────────────────────────────────────────────────
# Go service (services/telemetry/) running via systemd on port 7000.
# Receives data from 6DAiNAS-OS installs and the 6dainas.cloud website.
#
# DNS: A record → HomeLab IP, proxied through Cloudflare (orange cloud).
# TLS: Let's Encrypt via HTTP-01. Cloudflare SSL mode → Full (strict).
#
# Open:      POST /api/v1/os/register  (6DAiNAS-OS onboarding sync)
#            POST /api/v1/web/event    (website page-view beacons)
#            POST /api/v1/web/lead     (newsletter / contact form)
#            GET  /health
# Protected: GET  /api/v1/stats        (X-API-Key required)
#            GET  /api/v1/os/registrations
#            GET  /api/v1/web/events
#            GET  /api/v1/web/leads
# ─────────────────────────────────────────────────────────────────────────────
telemetry.6dainas.cloud {

    reverse_proxy localhost:7000 {
        transport http {
            dial_timeout            5s
            response_header_timeout 30s
            keepalive               30s
        }
        header_up X-Real-IP         {remote_host}
        header_up X-Forwarded-For   {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    header {
        X-Frame-Options         "DENY"
        X-Content-Type-Options  "nosniff"
        Referrer-Policy         "strict-origin-when-cross-origin"
        Permissions-Policy      "geolocation=(), microphone=(), camera=()"
        -Server
        -X-Powered-By
    }

    @tls_active `{tls_version} != ""`
    header @tls_active Strict-Transport-Security "max-age=31536000"

    encode {
        zstd
        gzip 6
        minimum_length 1024
    }

    log {
        output file /var/log/6dainas/telemetry-access.log {
            roll_size    10MiB
            roll_keep    7
            roll_keep_for 168h
        }
        format json
    }
}
