# Admin panel password — only you know this
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret for signing the admin session JWT (min 32 chars)
# Generate with: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-random-32-char-string

# Public URL of the analytics backend (proxied via Cloudflare → Caddy → port 7000)
ANALYTICS_URL=https://telemetry.6dainas.cloud

# API key for the analytics read endpoints (GET /api/v1/registrations, /stats)
# Must match ANALYTICS_KEY in /etc/systemd/system/6dainas-analytics.service
# Generate with: openssl rand -hex 32
ANALYTICS_KEY=your-analytics-api-key
