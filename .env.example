# ── Next.js Admin Panel ────────────────────────────────────────────────────────

# Password for /admin/login
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret for signing the admin session JWT (min 32 chars)
# Generate: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-random-32-char-string

# ── Telemetry Backend (services/telemetry Go service) ─────────────────────────

# Base URL of the telemetry backend
# Proxied through Cloudflare → Caddy → port 7000
ANALYTICS_URL=https://telemetry.6dainas.cloud

# API key protecting the GET /api/v1/* read endpoints
# Must match TELEMETRY_KEY in infra/systemd/6dainas-telemetry.service
# Generate: openssl rand -hex 32
ANALYTICS_KEY=your-telemetry-api-key

# ── Telemetry Service (set in systemd or Docker env, not in Next.js) ──────────

# TELEMETRY_PORT=7000
# TELEMETRY_DB=/var/lib/6dainas-telemetry/telemetry.db
# TELEMETRY_KEY=your-telemetry-api-key
# TELEMETRY_CORS_ORIGINS=https://6dainas.cloud
