# Admin panel password (only you know this)
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret for signing the admin session JWT (min 32 chars)
ADMIN_SECRET=change-me-to-a-random-32-char-string

# URL of the Go analytics backend (port 7000 on your HomeLab)
ANALYTICS_URL=http://localhost:7000

# API key for the Go analytics backend (must match ANALYTICS_KEY there)
ANALYTICS_KEY=your-analytics-api-key
